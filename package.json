{
  "name": "spotme",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:apk": "node ./scripts/build-android-apk.mjs",
    "ios": "node ./scripts/run-ios.mjs",
    "ios:clean": "node ./scripts/clean-ios.mjs",
    "ios:reset-build": "node ./scripts/reset-ios-build.mjs",
    "preios": "node ./scripts/ensure-ios-pods.mjs",
    "e2e:build:ios": "node ./scripts/build-detox.mjs ios.sim.debug",
    "e2e:test:ios": "node ./scripts/run-detox.mjs ios.sim.debug",
    "e2e:test:ios:perf": "node ./scripts/run-detox.mjs ios.sim.debug --testPathPattern e2e/perf-benchmark.e2e.js",
    "e2e:build:android": "node ./scripts/build-detox.mjs android.emu.debug",
    "e2e:test:android": "node ./scripts/run-detox.mjs android.emu.debug",
    "e2e:test:android:regression": "node ./scripts/run-detox.mjs android.emu.debug --testPathPattern \"e2e/(regression-checklist|profile-add-flow-persistence)\\.e2e\\.js\"",
    "e2e:test:android:regression:attached": "node ./scripts/run-detox.mjs android.att.debug --testPathPattern \"e2e/(regression-checklist|profile-add-flow-persistence)\\.e2e\\.js\"",
    "e2e:test:android:regression:direct": "npx detox test -c android.emu.debug --testPathPattern \"e2e/(regression-checklist|profile-add-flow-persistence)\\.e2e\\.js\"",
    "e2e:test:android:regression:attached:direct": "npx detox test -c android.att.debug --testPathPattern \"e2e/(regression-checklist|profile-add-flow-persistence)\\.e2e\\.js\"",
    "lint": "eslint .",
    "pods": "node ./scripts/install-ios-pods.mjs",
    "start": "react-native start",
    "test": "jest"
  },
  "dependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-proposal-private-methods": "^7.18.6",
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-camera-roll/camera-roll": "^7.4.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-community/slider": "^4.5.6",
    "@react-native-community/template": "^0.77.0",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@react-navigation/bottom-tabs": "7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "i18n-iso-countries": "^7.14.0",
    "i18next": "^23.12.2",
    "iconsax-react-nativejs": "^0.0.8",
    "react": "18.3.1",
    "react-i18next": "^15.1.3",
    "react-native": "0.77.0",
    "react-native-auth0": "^5.4.0",
    "react-native-calendars": "^1.1304.0",
    "react-native-capture-protection": "^2.4.1",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-config": "^1.6.1",
    "react-native-eject": "^1.0.2",
    "react-native-fast-image": "^8.6.3",
    "react-native-fs": "^2.20.0",
    "react-native-image-picker": "^8.2.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "^4.4.0",
    "react-native-share": "^10.0.0",
    "react-native-shimmer-placeholder": "^2.0.9",
    "react-native-svg": "^15.11.2",
    "react-native-svg-transformer": "^1.5.0",
    "react-native-video": "^6.13.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-vision-camera": "^4.7.3",
    "react-native-vision-camera-face-detector": "1.7.0",
    "react-native-worklets-core": "^1.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "^15.0.1",
    "@react-native-community/cli-platform-android": "15.0.1",
    "@react-native-community/cli-platform-ios": "15.0.1",
    "@react-native/babel-preset": "0.77.0",
    "@react-native/eslint-config": "0.77.0",
    "@react-native/metro-config": "0.77.0",
    "@react-native/typescript-config": "^0.77.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "detox": "^20.47.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "18.3.1",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "@react-navigation/bottom-tabs": "7.3.10"
  }
}
